  id          Int                     @id @default(autoincrement())
  title       String                  @default("")
  image       Photo?                  @relation("HomepageImage_image", fields: [imageId], references: [id])
  imageId     Int?                    @map("image")
  linkUrl     String                  @default("")
  sortOrder   Int?                    @default(0)
  status      HomepageImageStatusType @default(draft)
  createdAt   DateTime?
  updatedAt   DateTime?
  createdBy   User?                   @relation("HomepageImage_createdBy", fields: [createdById], references: [id])
  createdById Int?                    @map("createdBy")
  updatedBy   User?                   @relation("HomepageImage_updatedBy", fields: [updatedById], references: [id])
  updatedById Int?                    @map("updatedBy")

  @@index([imageId])
  @@index([createdById])
  @@index([updatedById])
}

model RssKeyword {
  id          Int                    @id @default(autoincrement())
  keyword     String                 @unique @default("")
  language    RssKeywordLanguageType @default(zh)
  note        String                 @default("")
  isEnabled   Boolean                @default(true)
  createdAt   DateTime?
  updatedAt   DateTime?
  createdBy   User?                  @relation("RssKeyword_createdBy", fields: [createdById], references: [id])
  createdById Int?                   @map("createdBy")
  updatedBy   User?                  @relation("RssKeyword_updatedBy", fields: [updatedById], references: [id])
  updatedById Int?                   @map("updatedBy")

  @@index([createdById])
  @@index([updatedById])
}

model RssTopicMapping {
  id          Int       @id @default(autoincrement())
  rssTopic    String    @unique @default("")
  topic       Topic?    @relation("RssTopicMapping_topic", fields: [topicId], references: [id])
  topicId     Int?      @map("topic")
  isEnabled   Boolean   @default(true)
  note        String    @default("")
  createdAt   DateTime?
  updatedAt   DateTime?
  createdBy   User?     @relation("RssTopicMapping_createdBy", fields: [createdById], references: [id])
  createdById Int?      @map("createdBy")
  updatedBy   User?     @relation("RssTopicMapping_updatedBy", fields: [updatedById], references: [id])
  updatedById Int?      @map("updatedBy")

  @@index([topicId])
  @@index([createdById])
  @@index([updatedById])
}

model Event {
  id                  Int                 @id @default(autoincrement())
  slug                String              @unique @default("")
  label               EventLabelType      @default(more)
  notice              String              @default("")
  post                Post?               @relation("Event_post", fields: [postId], references: [id])
  postId              Int?                @map("post")
  externalLink        String              @default("")
  startAt             DateTime?
  endAt               DateTime?
  registrationStartAt DateTime?
  registrationEndAt   DateTime?
  checkInStartAt      DateTime?
  checkInEndAt        DateTime?
  capacity            Int?
  registrations       EventRegistration[] @relation("EventRegistration_event")
  createdAt           DateTime?
  updatedAt           DateTime?
  createdBy           User?               @relation("Event_createdBy", fields: [createdById], references: [id])
  createdById         Int?                @map("createdBy")
  updatedBy           User?               @relation("Event_updatedBy", fields: [updatedById], references: [id])
  updatedById         Int?                @map("updatedBy")

  @@index([postId])
  @@index([createdById])
  @@index([updatedById])
}

model EventRegistration {
  id                  Int                                @id @default(autoincrement())
  event               Event?                             @relation("EventRegistration_event", fields: [eventId], references: [id])
  eventId             Int?                               @map("event")
  member              Member?                            @relation("EventRegistration_member", fields: [memberId], references: [id])
  memberId            Int?                               @map("member")
  status              EventRegistrationStatusType        @default(registered)
  registeredAt        DateTime?                          @default(now())
  checkedInAt         DateTime?
  checkedInBy         User?                              @relation("EventRegistration_checkedInBy", fields: [checkedInById], references: [id])
  checkedInById       Int?                               @map("checkedInBy")
  cancelledAt         DateTime?
  cancelledBy         User?                              @relation("EventRegistration_cancelledBy", fields: [cancelledById], references: [id])
  cancelledById       Int?                               @map("cancelledBy")
  identityType        EventRegistrationIdentityTypeType?
  identityMasked      String?
  identityHash        String?
  phoneMasked         String?
  phoneHash           String?
  lastQrTokenHash     String?
  lastQrTokenIssuedAt DateTime?
  lastQrTokenUsedAt   DateTime?
  checkInNotes        String                             @default("")
  createdAt           DateTime?
  updatedAt           DateTime?
  createdBy           User?                              @relation("EventRegistration_createdBy", fields: [createdById], references: [id])
  createdById         Int?                               @map("createdBy")
  updatedBy           User?                              @relation("EventRegistration_updatedBy", fields: [updatedById], references: [id])
  updatedById         Int?                               @map("updatedBy")

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@index([checkedInById])
  @@index([cancelledById])
  @@index([lastQrTokenHash])
  @@index([createdById])
  @@index([updatedById])
  @@index([eventId, status])
}

